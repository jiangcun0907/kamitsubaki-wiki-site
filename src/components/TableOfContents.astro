---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
---

<nav class="hidden lg:block w-64 shrink-0 px-4 sticky top-24 self-start max-h-[calc(100vh-6rem)] overflow-y-auto">
  <h3 class="text-xs font-mono tracking-widest text-white/40 mb-4 uppercase">Contents</h3>
  <ul class="space-y-2 text-sm font-sans border-l border-white/10 pl-4 toc-list">
    {headings.filter(h => h.depth === 2 || h.depth === 3).map((heading) => (
      <li class={`heading-level-${heading.depth}`}>
        <a 
          href={`#${heading.slug}`} 
          class="block py-1 text-white/60 hover:text-white hover:translate-x-1 transition-all duration-300"
          data-slug={heading.slug}
        >
          {heading.text}
        </a>
      </li>
    ))}
  </ul>
</nav>

<script>
  function initToC() {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const id = entry.target.getAttribute('id');
          const link = document.querySelector(`.toc-list a[data-slug="${id}"]`);
          
          if (entry.isIntersecting && link) {
            document.querySelectorAll('.toc-list a').forEach((a) => {
              a.classList.remove('text-white', 'font-bold', 'translate-x-1');
              a.classList.add('text-white/60');
            });
            link.classList.add('text-white', 'font-bold', 'translate-x-1');
            link.classList.remove('text-white/60');
          }
        });
      },
      { rootMargin: '0px 0px -80% 0px' }
    );

    document.querySelectorAll('h2[id], h3[id]').forEach((section) => {
      observer.observe(section);
    });
  }

  // Run on first load and on subsequent page navigations (if using View Transitions)
  initToC();
  document.addEventListener('astro:page-load', initToC);
</script>

<style>
  .heading-level-3 {
    margin-left: 1rem;
    font-size: 0.85em;
  }
</style>
