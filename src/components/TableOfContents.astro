---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
  title?: string;
}

const { headings, title = 'Contents' } = Astro.props as Props;
const visibleHeadings = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
---

<nav class="wiki-toc w-full max-h-[calc(100vh-10rem)] overflow-y-auto pr-2 custom-scrollbar" aria-label={title}>
  <div class="mb-4 flex items-center justify-between gap-3">
    <h3 class="text-xs font-mono tracking-widest text-white/40 uppercase">{title}</h3>
    <span class="text-[10px] font-mono text-white/25">{visibleHeadings.length}</span>
  </div>
  {visibleHeadings.length > 0 ? (
    <ul class="space-y-1 text-sm font-sans border-l border-white/10 pl-4 toc-list">
      {visibleHeadings.map((heading) => (
        <li class={`heading-level-${heading.depth}`}>
          <a
            href={`#${heading.slug}`}
            class="block rounded-sm py-1.5 pr-2 text-white/55 hover:text-white hover:translate-x-1 transition-all duration-300"
            data-slug={heading.slug}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  ) : (
    <p class="border-l border-white/10 pl-4 text-xs leading-relaxed text-white/35">
      No sections yet.
    </p>
  )}
</nav>

<script>
  function initToC() {
    if (document.documentElement.dataset.tocInitialized === 'true') {
      return;
    }

    document.documentElement.dataset.tocInitialized = 'true';

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const id = entry.target.getAttribute('id');
          const links = document.querySelectorAll(`.toc-list a[data-slug="${id}"]`);
          
          if (entry.isIntersecting && links.length > 0) {
            document.querySelectorAll('.toc-list a').forEach((a) => {
              a.classList.remove('text-white', 'font-bold', 'translate-x-1');
              a.classList.add('text-white/55');
            });
            links.forEach((link) => {
              link.classList.add('text-white', 'font-bold', 'translate-x-1');
              link.classList.remove('text-white/55');
            });
          }
        });
      },
      { rootMargin: '0px 0px -80% 0px' }
    );

    document.querySelectorAll('h2[id], h3[id]').forEach((section) => {
      observer.observe(section);
    });
  }

  initToC();
  document.addEventListener('astro:page-load', initToC);
</script>

<style>
  .heading-level-3 {
    margin-left: 1rem;
    font-size: 0.85em;
  }
</style>
