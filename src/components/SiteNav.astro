---
type NavItem = {
  label: string;
  href: string;
};

type LocaleLink = {
  code: string;
  label: string;
  shortLabel: string;
  href: string;
  current: boolean;
};

const { navItems, localeLinks, brandLines } = Astro.props as {
  navItems: NavItem[];
  localeLinks: LocaleLink[];
  brandLines: string[];
};
---

<nav class="fixed top-0 w-full z-50 mix-blend-difference px-6 md:px-12 py-8 flex justify-between items-start pointer-events-none">
  <a href="#" class="pointer-events-auto group">
    <h1 class="text-white text-[10px] md:text-xs tracking-kamidest font-light uppercase group-hover:opacity-50 transition-opacity duration-500 leading-relaxed">
      {brandLines.map((line, index) => (
        <>
          {line}{index < brandLines.length - 1 && <br />}
        </>
      ))}
    </h1>
  </a>
  <div class="pointer-events-auto flex flex-col items-end gap-3 text-[9px] md:text-[10px] tracking-kamidest-lg font-light text-white">
    {navItems.map((item) => (
      <a href={item.href} class="hover:text-white/50 transition-all duration-300">{item.label}</a>
    ))}
    <div class="mt-4 flex gap-3 font-mono tracking-widest text-[8px]" aria-label="Language switcher">
      {localeLinks.map((item) => (
        <a
          href={item.href}
          aria-current={item.current ? 'page' : undefined}
          title={item.label}
          class={item.current ? 'text-white' : 'text-white/35 hover:text-white transition-colors'}
        >
          {item.shortLabel}
        </a>
      ))}
    </div>
  </div>
</nav>
