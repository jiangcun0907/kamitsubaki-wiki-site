---
interface Props {
  data: {
    name: string;
    romanizedName: string;
    image: string;
    statusLabel: string;
    status: string;
    meta?: string;
    categoryTitle: string;
  };
}

const { data } = Astro.props;
---

<aside class="w-full sm:w-72 sm:float-right sm:ml-8 mb-8 backdrop-blur-md bg-white/5 border border-white/10 rounded-xl overflow-hidden shadow-2xl relative">
  <div class="absolute inset-0 bg-gradient-to-b from-transparent to-black/60 pointer-events-none"></div>
  
  <div class="p-1 bg-white/5">
    <img src={data.image} alt={data.name} class="w-full h-auto aspect-square object-cover rounded-lg filter contrast-125 grayscale-[20%]" />
  </div>
  
  <div class="p-5 relative z-10">
    <div class="flex items-baseline justify-between mb-2">
      <h2 class="text-3xl font-serif font-bold text-white tracking-wider">{data.name}</h2>
      <span class="text-sm font-sans tracking-widest text-white/50">{data.romanizedName}</span>
    </div>
    
    <div class="text-xs tracking-[0.2em] text-white/70 uppercase border-b border-white/10 pb-3 mb-4">
      {data.categoryTitle}
    </div>
    
    <dl class="space-y-3 text-sm font-sans">
      <div class="flex justify-between items-center border-b border-white/5 pb-2">
        <dt class="text-white/50 tracking-wider text-xs">STATUS</dt>
        <dd class="text-white tracking-widest flex items-center gap-2">
          {data.status === 'ACTIVE' && <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>}
          {data.status}
        </dd>
      </div>
      
      {data.meta && (
        <div class="flex justify-between items-center border-b border-white/5 pb-2">
          <dt class="text-white/50 tracking-wider text-xs">META</dt>
          <dd class="text-white">{data.meta}</dd>
        </div>
      )}
    </dl>
  </div>
</aside>
