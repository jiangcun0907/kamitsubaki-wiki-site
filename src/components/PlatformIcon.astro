---
import { detectExternalPlatform } from '../lib/externalPlatforms.mjs';

interface Props {
  href: string;
  label?: string;
  class?: string;
}

const { href, label = '', class: className = '' } = Astro.props;
const platform = detectExternalPlatform({ href, label });
---

<span class:list={['platform-icon', className]} style={`--platform-color:${platform.color}`} data-platform={platform.id} title={platform.name} aria-hidden="true">
  {platform.icon ? (
    <svg viewBox="0 0 24 24" role="img" focusable="false"><path d={platform.icon.path}></path></svg>
  ) : (
    <svg viewBox="0 0 24 24" role="img" focusable="false" class="platform-icon__globe">
      <circle cx="12" cy="12" r="8.75"></circle>
      <path d="M3.5 12h17M12 3.25c2.2 2.35 3.3 5.27 3.3 8.75S14.2 18.4 12 20.75C9.8 18.4 8.7 15.48 8.7 12S9.8 5.6 12 3.25Z"></path>
    </svg>
  )}
</span>

