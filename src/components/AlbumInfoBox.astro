---
import ExternalLinkCard from './ExternalLinkCard.astro';

type AlbumData = {
  title: string;
  romanizedTitle?: string;
  artist: string;
  type?: string;
  releaseDate?: string;
  label?: string;
  catalogNumber?: string;
  trackCount?: number;
  duration?: string;
  image?: string;
  officialLinks?: { label: string; href: string }[];
};

const { data, labels } = Astro.props as {
  data: AlbumData;
  labels: {
    infobox: string;
    artist: string;
    type: string;
    releaseDate: string;
    label: string;
    catalogNumber: string;
    trackCount: string;
    duration: string;
    officialLinks: string;
    coverPlaceholder: string;
  };
};

const details = [
  [labels.artist, data.artist],
  [labels.type, data.type],
  [labels.releaseDate, data.releaseDate],
  [labels.label, data.label],
  [labels.catalogNumber, data.catalogNumber],
  [labels.trackCount, data.trackCount],
  [labels.duration, data.duration],
].filter(([, value]) => value !== undefined && value !== '');

---

<aside class="wiki-infobox w-full overflow-hidden rounded-md border border-white/10 bg-white/[0.035] shadow-2xl backdrop-blur-md sm:rounded-lg">
  <div class="border-b border-white/10 bg-white/[0.03] px-3 py-2.5 sm:px-4 sm:py-3">
    <p class="font-mono text-[9px] uppercase tracking-[0.24em] text-white/35 sm:text-[10px]">{labels.infobox}</p>
    <h2 class="mt-1 font-serif text-xl font-semibold tracking-[0.1em] text-white sm:text-2xl">{data.title}</h2>
    {data.romanizedTitle && <p class="mt-1 text-[10px] tracking-[0.16em] text-white/40">{data.romanizedTitle}</p>}
  </div>

  {data.image ? (
    <figure class="bg-black/30 p-1">
      <img src={data.image} alt={data.title} class="aspect-square w-full rounded-sm object-cover sm:rounded-md" />
    </figure>
  ) : (
    <div class="flex aspect-square items-center justify-center bg-black/30 p-6 text-center font-mono text-[10px] uppercase tracking-[0.22em] text-white/20">
      {labels.coverPlaceholder}
    </div>
  )}

  <div class="p-3 sm:p-4">
    <dl class="divide-y divide-white/5 text-xs sm:text-sm">
      {details.map(([label, value]) => (
        <div class="grid grid-cols-[5.75rem_1fr] gap-3 py-2.5 sm:grid-cols-[6.5rem_1fr] sm:py-3">
          <dt class="font-mono text-[9px] uppercase tracking-[0.18em] text-white/35 sm:text-[10px]">{label}</dt>
          <dd class="text-white/80">{value}</dd>
        </div>
      ))}

      {data.officialLinks && data.officialLinks.length > 0 && (
        <div class="py-2.5 sm:py-3">
          <dt class="font-mono text-[9px] uppercase tracking-[0.18em] text-white/35 sm:text-[10px]">{labels.officialLinks}</dt>
          <dd class="mt-2 space-y-2">
            {data.officialLinks.map((item) => (
              <ExternalLinkCard href={item.href} label={item.label} compact />
            ))}
          </dd>
        </div>
      )}
    </dl>
  </div>
</aside>
