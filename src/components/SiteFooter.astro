---
import { getLocalizedSiteName } from '../lib/i18n.mjs';

type FooterLink = {
  label: string;
  href: string;
};

type FooterContent = {
  tagline: string;
  links: FooterLink[];
  disclaimer: string[];
  license: {
    notice: string;
    mediaNotice: string;
    detailsLabel: string;
    detailsHref: string;
    deedLabel: string;
    deedHref: string;
  };
  copyright: string;
};

const { footer } = Astro.props as { footer: FooterContent };
const footerLogoAlt = getLocalizedSiteName(Astro.params.locale);
---

<footer class="relative mt-14 overflow-hidden border-t border-white/10 py-14 text-center ui-crosshair tl tr sm:mt-20 sm:py-20">
  <div class="mx-auto flex max-w-4xl flex-col items-center px-5 sm:px-6">
    <p class="mb-8 font-serif text-sm tracking-[0.34em] text-white/80 sm:mb-12 sm:tracking-[0.5em] md:text-base">
      {footer.tagline}
    </p>

    <div class="mb-10 flex flex-wrap justify-center gap-x-7 gap-y-4 text-[9px] font-light tracking-kamidest text-white/40 sm:mb-16 sm:gap-12">
      {footer.links.map((link) => (
        <a href={link.href} class="hover:text-white transition-colors relative after:content-[''] after:absolute after:-bottom-2 after:left-0 after:w-0 after:h-[1px] after:bg-white hover:after:w-full after:transition-all">
          {link.label}
        </a>
      ))}
    </div>

    <div class="mb-8 h-10 w-px bg-white/10 sm:mb-12 sm:h-12"></div>

    <p class="text-[9px] text-white/30 tracking-widest max-w-lg mb-6 font-light leading-loose uppercase">
      {footer.disclaimer.map((line) => (
        <>
          {line}<br />
        </>
      ))}
    </p>
    <div class="mb-6 max-w-2xl text-[10px] font-light leading-6 text-white/42">
      <p>{footer.license.notice}</p>
      <p class="mt-1 text-white/30">{footer.license.mediaNotice}</p>
      <p class="mt-2 flex flex-wrap justify-center gap-x-3 gap-y-1 font-mono text-[9px] uppercase tracking-[0.14em]">
        <a href={footer.license.detailsHref} class="transition-colors hover:text-white">
          {footer.license.detailsLabel}
        </a>
        <span aria-hidden="true" class="text-white/15">/</span>
        <a rel="license" href={footer.license.deedHref} class="transition-colors hover:text-white">
          {footer.license.deedLabel}
        </a>
      </p>
    </div>
    <p class="text-[9px] font-mono text-white/20 tracking-widest">
      {footer.copyright}
    </p>

    <div class="mt-12 w-full pr-12 sm:mt-16 sm:pr-0">
      <img
        src="/brand/kamitsubakiwiki-long-dark.svg"
        alt={footerLogoAlt}
        width="1577"
        height="400"
        loading="lazy"
        decoding="async"
        class="footer-brand-logo footer-brand-logo--dark mx-auto h-auto w-full max-w-3xl opacity-25"
      />
      <img
        src="/brand/kamitsubakiwiki-long-light.svg"
        alt=""
        aria-hidden="true"
        width="1577"
        height="400"
        loading="lazy"
        decoding="async"
        class="footer-brand-logo footer-brand-logo--light mx-auto h-auto w-full max-w-3xl opacity-25"
      />
    </div>
  </div>
</footer>
