---
type FooterLink = {
  label: string;
  href: string;
};

type FooterContent = {
  tagline: string;
  links: FooterLink[];
  disclaimer: string[];
  copyright: string;
};

const { footer } = Astro.props as { footer: FooterContent };
---

<footer class="mt-20 border-t border-white/10 py-20 text-center relative overflow-hidden ui-crosshair tl tr">
  <div class="max-w-4xl mx-auto px-6 flex flex-col items-center">
    <p class="font-serif text-sm md:text-base tracking-[0.5em] text-white/80 mb-12">
      {footer.tagline}
    </p>

    <div class="flex gap-12 text-[9px] tracking-kamidest font-light text-white/40 mb-16">
      {footer.links.map((link) => (
        <a href={link.href} class="hover:text-white transition-colors relative after:content-[''] after:absolute after:-bottom-2 after:left-0 after:w-0 after:h-[1px] after:bg-white hover:after:w-full after:transition-all">
          {link.label}
        </a>
      ))}
    </div>

    <div class="w-[1px] h-12 bg-white/10 mb-12"></div>

    <p class="text-[9px] text-white/30 tracking-widest max-w-lg mb-6 font-light leading-loose uppercase">
      {footer.disclaimer.map((line) => (
        <>
          {line}<br />
        </>
      ))}
    </p>
    <p class="text-[9px] font-mono text-white/20 tracking-widest">
      {footer.copyright}
    </p>
  </div>
</footer>
