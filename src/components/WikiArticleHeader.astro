---
type LocaleLink = {
  code: string;
  label: string;
  shortLabel: string;
  href: string;
  current: boolean;
};

type Labels = {
  home: string;
  artists: string;
  article: string;
  category: string;
  source: string;
  languages: string;
};

type Props = {
  data: {
    name: string;
    romanizedName: string;
    categoryTitle: string;
    categorySubtitle: string;
    statusLabel: string;
    status: string;
    meta?: string;
  };
  localeLinks: LocaleLink[];
  labels: Labels;
  sourceHref: string;
  homeHref: string;
};

const { data, localeLinks, labels, sourceHref, homeHref } = Astro.props as Props;
---

<header class="wiki-article-header border-b border-white/10 pb-4">
  <nav aria-label="Breadcrumb" class="mb-4 flex flex-wrap items-center gap-2 text-[9px] font-mono uppercase tracking-[0.22em] text-white/35">
    <a href={homeHref} class="hover:text-white transition-colors">{labels.home}</a>
    <span class="text-white/15">/</span>
    <span>{labels.artists}</span>
    <span class="text-white/15">/</span>
    <span class="text-white/60">{data.name}</span>
  </nav>

  <div class="grid gap-4 xl:grid-cols-[minmax(0,1fr)_auto] xl:items-end">
    <div>
      <p class="mb-2 text-[9px] font-mono uppercase tracking-[0.26em] text-white/35">
        {labels.article}
      </p>
      <h1 class="wiki-page-title font-serif text-4xl font-semibold tracking-[0.08em] text-white md:text-5xl">
        {data.name}
      </h1>
      <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-2 text-[11px] leading-none tracking-[0.14em] text-white/45">
        <span>{data.romanizedName}</span>
        <span class="hidden h-px w-8 bg-white/15 sm:block"></span>
        <span>{labels.category}: {data.categoryTitle}</span>
      </div>
    </div>

    <div class="flex flex-wrap items-center gap-3 text-[9px] font-mono uppercase tracking-[0.18em] text-white/45 xl:justify-end">
      <div class="flex flex-wrap gap-2" aria-label={labels.languages}>
        {localeLinks.map((item) => (
          <a
            href={item.href}
            aria-current={item.current ? 'page' : undefined}
            title={item.label}
            class={item.current ? 'wiki-chip text-white border-white/40' : 'wiki-chip hover:text-white hover:border-white/30'}
          >
            {item.shortLabel}
          </a>
        ))}
      </div>
      <a href={sourceHref} class="wiki-source-link" target="_blank" rel="noopener noreferrer">
        {labels.source}
      </a>
    </div>
  </div>

  <dl class="mt-4 flex flex-wrap gap-x-5 gap-y-2 border-t border-white/10 pt-3 text-[10px]">
    <div class="flex items-baseline gap-2">
      <dt class="font-mono uppercase tracking-[0.2em] text-white/30">{data.statusLabel}</dt>
      <dd class="leading-none tracking-[0.12em] text-white/75">{data.status}</dd>
    </div>
    <div class="flex items-baseline gap-2">
      <dt class="font-mono uppercase tracking-[0.2em] text-white/30">{labels.category}</dt>
      <dd class="leading-none tracking-[0.12em] text-white/75">{data.categorySubtitle}</dd>
    </div>
    {data.meta && (
      <div class="flex items-baseline gap-2">
        <dt class="font-mono uppercase tracking-[0.2em] text-white/30">Meta</dt>
        <dd class="leading-none tracking-[0.12em] text-white/75">{data.meta}</dd>
      </div>
    )}
  </dl>
</header>
