---
type LocaleLink = {
  code: string;
  label: string;
  shortLabel: string;
  href: string;
  current: boolean;
};

type Labels = {
  home: string;
  artists?: string;
  songs?: string;
  albums?: string;
  section?: string;
  article: string;
  category: string;
  source: string;
  languages: string;
};

type Props = {
  data: {
    name: string;
    romanizedName: string;
    categoryTitle?: string;
    categorySubtitle?: string;
    profileTagline?: string;
    statusLabel?: string;
    status?: string;
    meta?: string;
  };
  localeLinks: LocaleLink[];
  labels: Labels;
  sourceHref: string;
  homeHref: string;
};

const { data, localeLinks, labels, sourceHref, homeHref } = Astro.props as Props;
const sectionLabel = labels.section ?? labels.artists ?? labels.songs ?? labels.albums;
---

<header class="wiki-article-header border-b border-white/10 pb-3 sm:pb-4 reveal-up">
  <nav aria-label="Breadcrumb" class="mb-4 hidden flex-wrap items-center gap-2 text-[9px] font-mono uppercase tracking-[0.22em] text-white/35 sm:flex">
    <a href={homeHref} class="hover:text-white transition-colors">{labels.home}</a>
    <span class="text-white/15">/</span>
    {sectionLabel && <span>{sectionLabel}</span>}
    <span class="text-white/15">/</span>
    <span class="text-white/60">{data.name}</span>
  </nav>

  <div class="grid gap-3 sm:gap-4 xl:grid-cols-[minmax(0,1fr)_auto] xl:items-end">
    <div>
      <p class="mb-2 hidden text-[8px] font-mono uppercase tracking-[0.24em] text-white/35 sm:block sm:text-[9px] sm:tracking-[0.26em]">
        {labels.article}
      </p>
      <h1 class="wiki-page-title font-serif text-[2rem] font-semibold tracking-[0.06em] text-white sm:text-4xl sm:tracking-[0.08em] md:text-5xl">
        {data.name}
      </h1>
      {data.profileTagline && (
        <p class="mt-3 max-w-3xl text-sm leading-7 text-white/62 sm:text-[15px]">{data.profileTagline}</p>
      )}
      <div class="mt-2 flex flex-wrap items-center gap-x-3 gap-y-1.5 text-[10px] leading-none tracking-[0.12em] text-white/45 sm:mt-3 sm:gap-x-4 sm:text-[11px] sm:tracking-[0.14em]">
        <span>{data.romanizedName}</span>
        <span class="hidden h-px w-8 bg-white/15 sm:block"></span>
        {data.categoryTitle && <span class="hidden sm:inline">{labels.category}: {data.categoryTitle}</span>}
      </div>
    </div>

    <div class="flex flex-wrap items-center gap-2 text-[8px] font-mono uppercase tracking-[0.14em] text-white/45 sm:gap-3 sm:text-[9px] sm:tracking-[0.18em] xl:justify-end">
      <div class="flex flex-wrap gap-1.5 sm:gap-2" aria-label={labels.languages}>
        {localeLinks.map((item) => (
          <a
            href={item.href}
            aria-current={item.current ? 'page' : undefined}
            title={item.label}
            class={item.current ? 'wiki-chip text-white border-white/40' : 'wiki-chip hover:text-white hover:border-white/30'}
          >
            {item.shortLabel}
          </a>
        ))}
      </div>
      <a href={sourceHref} class="wiki-source-link">
        {labels.source}
      </a>
    </div>
  </div>

  <dl class="mt-4 hidden flex-wrap gap-x-5 gap-y-2 border-t border-white/10 pt-3 text-[10px] sm:flex">
    {data.statusLabel && data.status && (
      <div class="flex items-baseline gap-2">
        <dt class="font-mono uppercase tracking-[0.16em] text-white/30 sm:tracking-[0.2em]">{data.statusLabel}</dt>
        <dd class="leading-none tracking-[0.1em] text-white/75 sm:tracking-[0.12em]">{data.status}</dd>
      </div>
    )}
    {data.categorySubtitle && (
      <div class="flex items-baseline gap-2">
        <dt class="font-mono uppercase tracking-[0.16em] text-white/30 sm:tracking-[0.2em]">{labels.category}</dt>
        <dd class="truncate leading-none tracking-[0.1em] text-white/75 sm:tracking-[0.12em]">{data.categorySubtitle}</dd>
      </div>
    )}
    {data.meta && (
      <div class="col-span-2 flex items-baseline gap-2 sm:col-span-1">
        <dt class="font-mono uppercase tracking-[0.16em] text-white/30 sm:tracking-[0.2em]">Meta</dt>
        <dd class="leading-none tracking-[0.1em] text-white/75 sm:tracking-[0.12em]">{data.meta}</dd>
      </div>
    )}
  </dl>
</header>
