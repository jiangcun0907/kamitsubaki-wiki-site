---
type ThemeToggleCopy = {
  label: string;
  system: string;
  light: string;
  dark: string;
};

const { copy } = Astro.props as { copy: ThemeToggleCopy };
---

<div class="theme-toggle" data-theme-toggle data-copy={JSON.stringify(copy)} aria-live="polite">
  <button type="button" class="theme-toggle__button" data-theme-toggle-button aria-label={copy.label} title={copy.label}>
    <svg class="theme-toggle__icon" data-theme-icon="system" viewBox="0 0 24 24" aria-hidden="true">
      <rect x="3" y="4" width="18" height="13" rx="1"></rect><path d="M8 21h8M12 17v4"></path>
    </svg>
    <svg class="theme-toggle__icon" data-theme-icon="light" viewBox="0 0 24 24" aria-hidden="true">
      <circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.93 4.93l1.42 1.42M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.42-1.42M17.66 6.34l1.41-1.41"></path>
    </svg>
    <svg class="theme-toggle__icon" data-theme-icon="dark" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M20.5 14.4A8.5 8.5 0 0 1 9.6 3.5 8.5 8.5 0 1 0 20.5 14.4Z"></path>
    </svg>
    <span data-theme-toggle-label>{copy.system}</span>
  </button>
</div>

<script>
  import '../scripts/themeToggle.js';
</script>
