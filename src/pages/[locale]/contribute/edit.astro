---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteNav from '../../../components/SiteNav.astro';
import SiteFooter from '../../../components/SiteFooter.astro';
import TableOfContents from '../../../components/TableOfContents.astro';
import { getLocalizedSite } from '../../../lib/homeData.mjs';
import { buildLocaleLinks, defaultLocale, supportedLocales } from '../../../lib/i18n.mjs';
import { renderMarkdownFragment } from '../../../lib/markdown.mjs';
import { renderContentEntry } from '../../../lib/contentSource.mjs';

export function getStaticPaths() {
  return supportedLocales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
const localeCode = locale as 'zh' | 'ja' | 'en';
const siteEntries = await getCollection('site');
const guideEntries = await getCollection('editGuide');
const syntaxEntries = await getCollection('syntaxGuide');
const homeContent = getLocalizedSite(siteEntries, localeCode, defaultLocale);
const copy =
  guideEntries.find((entry) => entry.data.locale === localeCode)?.data ??
  guideEntries.find((entry) => entry.data.locale === defaultLocale)?.data;
const currentPath = '/contribute/edit';
const localeLinks = buildLocaleLinks(homeContent, localeCode, currentPath);
const alternates = supportedLocales.map((code) => ({ locale: code, href: `/${code}${currentPath}` }));

if (!copy) throw new Error(`Missing edit guide content for locale: ${localeCode}`);

const syntaxEntry =
  syntaxEntries.find((entry) => entry.data.locale === localeCode) ??
  syntaxEntries.find((entry) => entry.data.locale === defaultLocale);

if (!syntaxEntry) throw new Error(`Missing syntax guide content for locale: ${localeCode}`);

const { html: syntaxHtml, headings: syntaxHeadings } = await renderContentEntry(syntaxEntry);
const syntaxSourcePath = `src/content/contribute/syntax-guide/${localeCode}.md`;
const syntaxEditHref = `/${localeCode}/contribute/edit?target=${encodeURIComponent(syntaxSourcePath)}#syntax-reference`;
const syntaxStandaloneHref = `/${localeCode}/contribute/syntax`;
const learningCopy = {
  zh: {
    navLabel: '贡献学习中心',
    journey: '分步贡献路线',
    reference: 'Markdown 与属性参考',
    start: '从路线开始',
    referenceEyebrow: '02 / 随用随查',
    referenceTitle: '写内容时，答案就在同一页。',
    referenceIntro: '不必离开贡献流程，也不必一次记住全部语法。先完成与你当前修改有关的部分；遇到格式、媒体或 frontmatter 字段时，再从目录直接跳到对应章节。',
    contents: '本页目录',
    standalone: '在独立阅读页打开',
    editReference: '改进这份参考',
    workflowTitle: '推荐学习顺序',
    workflow: ['先选一条贡献路线', '确认目标文件与语言', '修改时按需查语法', '预览差异并提交 PR'],
  },
  ja: {
    navLabel: 'コントリビューション学習センター',
    journey: 'ステップ別ガイド',
    reference: 'Markdown・属性リファレンス',
    start: 'ガイドから始める',
    referenceEyebrow: '02 / 必要なときに参照',
    referenceTitle: '編集に必要な答えを、このページだけで。',
    referenceIntro: '貢献フローから離れたり、すべての構文を暗記したりする必要はありません。まず現在の変更に必要な部分を進め、書式・メディア・frontmatter で迷ったときに目次から該当章へ移動してください。',
    contents: 'ページ内目次',
    standalone: '独立した閲覧ページで開く',
    editReference: 'このリファレンスを改善',
    workflowTitle: 'おすすめの学習順序',
    workflow: ['自分に合うルートを選ぶ', '対象ファイルと言語を確認', '編集中に構文を参照', '差分を確認して PR を送る'],
  },
  en: {
    navLabel: 'Contribution learning center',
    journey: 'Step-by-step contribution routes',
    reference: 'Markdown and property reference',
    start: 'Start with a route',
    referenceEyebrow: '02 / Look up as you work',
    referenceTitle: 'Keep every editing answer on the same page.',
    referenceIntro: 'You do not need to leave the contribution flow or memorize the whole reference. Complete only what your change needs, then jump to the relevant section when you meet a formatting, media, or frontmatter question.',
    contents: 'On this page',
    standalone: 'Open the focused reading view',
    editReference: 'Improve this reference',
    workflowTitle: 'Recommended learning order',
    workflow: ['Choose a contribution route', 'Confirm the file and locale', 'Look up syntax while editing', 'Review the diff and open a PR'],
  },
}[localeCode];

const docsHref = `https://github.com/LinkTh1rsty/kamitsubaki-wiki-site/blob/main/${copy.docsPath}`;
const repoEditRoot = 'https://github.com/LinkTh1rsty/kamitsubaki-wiki-site/edit/main/';
const repoContentRoot = 'https://github.com/LinkTh1rsty/kamitsubaki-wiki-site/tree/main/src/content';
const contentPathPrefix = 'src/content/';
const introHtml = await renderMarkdownFragment(copy.intro);
const targetIntroHtml = await renderMarkdownFragment(copy.targetIntro);
const renderedVariants = await Promise.all(
  copy.variants.map(async (variant) => ({
    ...variant,
    descriptionHtml: await renderMarkdownFragment(variant.description),
    finalBodyHtml: await renderMarkdownFragment(variant.finalBody),
    renderedSections: await Promise.all(
      variant.sections.map(async (section, index) => ({
        ...section,
        id: `${variant.key}-step-${index + 1}`,
        bodyHtml: await renderMarkdownFragment(section.body),
      })),
    ),
  })),
);
const modeKeys = renderedVariants.map((variant) => variant.key).join(',');

const metadata = {
  title: `${copy.title} - Kamitsubaki Studio Fan Wiki`,
  description: copy.intro,
  canonicalPath: `/${localeCode}/contribute/edit`,
  type: 'website' as const,
  noindex: true,
};
---

<BaseLayout lang={localeCode} alternates={alternates} title={`${copy.title} - Kamitsubaki Studio Fan Wiki`} metadata={metadata}>
  <SiteNav navItems={homeContent.navItems} localeLinks={localeLinks} brandLines={homeContent.hero.brandLines} compact homeHref={`/${localeCode}/`} />

  <main
    class="guide-shell mx-auto min-h-screen max-w-7xl px-4 pb-16 pt-24 sm:px-6 sm:pt-28 lg:px-8 lg:pt-32"
    data-guide-runtime
    data-repo-edit-root={repoEditRoot}
    data-repo-content-root={repoContentRoot}
    data-content-path-prefix={contentPathPrefix}
    data-docs-href={docsHref}
    data-invalid-target={copy.invalidTarget}
    data-default-guide-mode="beginner"
    data-guide-modes={modeKeys}
    data-complete-label={copy.completeLabel}
    data-completed-label={copy.completedLabel}
    data-progress-label={copy.progressLabel}
    data-ai-copy-label={copy.aiCopyLabel}
    data-ai-copied-label={copy.aiCopiedLabel}
    data-ai-no-context={copy.aiNoContext}
    data-ai-guardrails={copy.aiGuardrails}
  >
    <div class="mb-8 flex flex-wrap items-center justify-between gap-4 text-[9px] font-mono uppercase tracking-[0.22em] text-white/40">
      <a href={`/${localeCode}/`} class="transition-colors hover:text-white">{copy.back}</a>
      <a href={docsHref} class="transition-colors hover:text-white" target="_blank" rel="noopener noreferrer">{copy.docs}</a>
    </div>

    <nav class="guide-workspace-nav" aria-label={learningCopy.navLabel}>
      <p>{learningCopy.navLabel}</p>
      <div>
        <a href="#choose-guide">
          <span>01</span>
          {learningCopy.journey}
        </a>
        <a href="#syntax-reference">
          <span>02</span>
          {learningCopy.reference}
        </a>
      </div>
    </nav>

    <section class="guide-hero border-y border-white/10 py-10 sm:py-14 lg:py-16">
      <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(25rem,0.8fr)] lg:items-center">
        <div>
          <p class="mb-4 text-[9px] font-mono uppercase tracking-[0.28em] text-white/35">{copy.eyebrow}</p>
          <h1 class="max-w-3xl font-serif text-[2.4rem] font-semibold leading-[1.16] tracking-[0.04em] text-white sm:text-5xl lg:text-6xl">
            {copy.title}
          </h1>
          <div class="wiki-guide-prose prose prose-invert mt-6 max-w-2xl" set:html={introHtml} />
          <button type="button" class="guide-primary-action mt-8" data-guide-start>
            <span>{copy.primaryAction}</span>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
          </button>
        </div>

        <div class="guide-journey" aria-label={copy.journeyLabel}>
          <p class="text-[9px] font-mono uppercase tracking-[0.22em] text-white/35">{copy.journeyLabel}</p>
          <ol class="mt-7 grid grid-cols-3">
            {copy.journeySteps.map((step, index) => (
              <li class="relative text-center">
                <span class="guide-journey__line" aria-hidden="true"></span>
                <span class="guide-journey__node">{String(index + 1).padStart(2, '0')}</span>
                <span class="mt-4 block font-serif text-sm tracking-[0.08em] text-white/78 sm:text-base">{step}</span>
              </li>
            ))}
          </ol>
        </div>
      </div>

      <div class="guide-target mt-10 grid gap-4 border border-white/10 px-4 py-4 sm:grid-cols-[auto_minmax(0,1fr)] sm:items-center sm:px-5">
        <div>
          <p class="text-[9px] font-mono uppercase tracking-[0.2em] text-white/35">{copy.targetLabel}</p>
          <div class="wiki-guide-prose prose prose-invert mt-2 max-w-2xl text-sm" set:html={targetIntroHtml} />
        </div>
        <p class="break-all font-mono text-xs leading-6 text-cyan-100/80 sm:text-right" data-guide-target-path>{copy.invalidTarget}</p>
      </div>
    </section>

    <section class="py-10 sm:py-14" id="choose-guide" data-guide-chooser>
      <div class="mb-8 max-w-3xl">
        <p class="text-[9px] font-mono uppercase tracking-[0.22em] text-cyan-200/60">01 / Route</p>
        <h2 class="mt-3 font-serif text-2xl tracking-[0.06em] text-white sm:text-3xl">{copy.switchLabel}</h2>
        <p class="mt-3 text-sm leading-7 text-white/52">{copy.switchHint}</p>
      </div>

      <div class="guide-route-list" role="tablist" aria-label={copy.switchLabel}>
        {renderedVariants.map((variant, index) => (
          <button
            type="button"
            role="tab"
            aria-selected={index === 0 ? 'true' : 'false'}
            tabindex={index === 0 ? 0 : -1}
            class="guide-route"
            data-guide-mode-button={variant.key}
            data-guide-mode-active={index === 0 ? 'true' : 'false'}
            aria-controls={`guide-panel-${variant.key}`}
            id={`guide-tab-${variant.key}`}
          >
            <span class="guide-route__number">{String(index + 1).padStart(2, '0')}</span>
            <span class="min-w-0 flex-1 text-left">
              <span class="block font-serif text-lg tracking-[0.05em] text-white sm:text-xl">{variant.label}</span>
              <span class="mt-2 block text-sm leading-6 text-white/50">{variant.summary}</span>
              <span class="mt-5 grid gap-3 border-t border-white/10 pt-4 sm:grid-cols-2">
                <span>
                  <span class="block font-mono text-[8px] uppercase tracking-[0.18em] text-white/30">{copy.durationLabel}</span>
                  <span class="mt-1 block text-xs text-white/68">{variant.duration}</span>
                </span>
                <span>
                  <span class="block font-mono text-[8px] uppercase tracking-[0.18em] text-white/30">{copy.outcomeLabel}</span>
                  <span class="mt-1 block text-xs text-white/68">{variant.outcome}</span>
                </span>
              </span>
            </span>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
          </button>
        ))}
      </div>
    </section>

    {renderedVariants.map((variant, variantIndex) => (
      <section
        id={`guide-panel-${variant.key}`}
        role="tabpanel"
        aria-labelledby={`guide-tab-${variant.key}`}
        hidden={variantIndex !== 0}
        data-guide-mode-panel={variant.key}
        data-step-count={variant.renderedSections.length}
      >
        <div class="mb-9 border-l border-cyan-200/45 pl-5 sm:pl-7">
          <p class="text-[9px] font-mono uppercase tracking-[0.22em] text-cyan-200/65">{variant.audience}</p>
          <div class="wiki-guide-prose prose prose-invert mt-3 max-w-3xl" set:html={variant.descriptionHtml} />
        </div>

        <div class="guide-progress-card guide-progress-card--mobile mb-8 lg:hidden">
          <div class="guide-progress-card__topline">
            <div>
              <p class="guide-progress-card__route">{variant.label}</p>
              <p class="guide-progress-card__count" data-guide-progress-text>{copy.progressLabel} 0 / {variant.renderedSections.length}</p>
            </div>
            <button type="button" class="guide-progress-card__reset" data-guide-reset data-reset-confirm={copy.resetConfirm}>{copy.resetLabel}</button>
          </div>
          <span class="guide-progress-card__track"><span data-guide-progress-fill></span></span>
        </div>

        <div class="grid gap-8 lg:grid-cols-[15rem_minmax(0,1fr)_16rem] lg:items-start xl:grid-cols-[17rem_minmax(0,1fr)_18rem]">
          <aside class="hidden lg:sticky lg:top-28 lg:block">
            <div class="guide-progress-card mb-5">
              <div class="guide-progress-card__topline">
                <div>
                  <p class="guide-progress-card__route">{variant.label}</p>
                  <p class="guide-progress-card__count" data-guide-progress-text>{copy.progressLabel} 0 / {variant.renderedSections.length}</p>
                </div>
                <button type="button" class="guide-progress-card__reset" data-guide-reset data-reset-confirm={copy.resetConfirm}>{copy.resetLabel}</button>
              </div>
              <span class="guide-progress-card__track"><span data-guide-progress-fill></span></span>
            </div>
            <nav class="guide-step-rail" data-guide-rail={variant.key} aria-label={variant.label}>
              {variant.renderedSections.map((section, index) => (
                <a href={`#${section.id}`} data-step-rail-link={index}>
                  <span>{String(index + 1).padStart(2, '0')}</span>
                  <span>{section.title}</span>
                  <span class="guide-step-rail__check" aria-hidden="true">✓</span>
                </a>
              ))}
            </nav>
          </aside>

          <div class="min-w-0 space-y-6">
            {variant.renderedSections.map((section, index) => (
              <article id={section.id} class="guide-step" data-guide-step={index}>
                <header class="guide-step__header">
                  <span class="guide-step__number">{String(index + 1).padStart(2, '0')}</span>
                  <div class="min-w-0">
                    <p class="font-mono text-[9px] uppercase tracking-[0.2em] text-cyan-200/60">Step {String(index + 1).padStart(2, '0')}</p>
                    <h3 class="mt-2 font-serif text-xl tracking-[0.05em] text-white sm:text-2xl">{section.title}</h3>
                    <p class="mt-3 text-sm leading-7 text-cyan-50/64">{section.summary}</p>
                  </div>
                </header>

                <div class="wiki-guide-prose prose prose-invert max-w-none px-5 py-6 sm:px-7" set:html={section.bodyHtml} />

                {section.action && (
                  <div class="px-5 pb-6 sm:px-7">
                    <a href={section.action.href} class="guide-external-action" target="_blank" rel="noopener noreferrer">
                      <span>{section.action.label}</span>
                      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 17 17 7M8 7h9v9" /></svg>
                    </a>
                  </div>
                )}

                <div class="guide-checkpoint mx-5 mb-6 sm:mx-7">
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m5 12 4 4L19 6" /></svg>
                  <p><strong>{copy.checkpointLabel}</strong> {section.checkpoint}</p>
                </div>

                {section.aiPrompt && (
                  <details class="guide-ai-help mx-5 mb-6 sm:mx-7">
                    <summary>
                      <span>{copy.aiHelpTitle}</span>
                      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m6 9 6 6 6-6" /></svg>
                    </summary>
                    <div class="border-t border-white/10 p-4 sm:p-5">
                      <p class="text-sm leading-7 text-white/52">{copy.aiHelpBody}</p>
                      <p class="guide-ai-privacy mt-3">{copy.aiPrivacyNote}</p>
                      <label class="guide-ai-context mt-5">
                        <span>{copy.aiContextLabel}</span>
                        <textarea rows="4" maxlength="600" placeholder={copy.aiContextPlaceholder} data-ai-context></textarea>
                      </label>
                      <div class="mt-5 flex items-center justify-between gap-4">
                        <p class="font-mono text-[9px] uppercase tracking-[0.16em] text-white/35">{copy.aiPromptPreviewLabel}</p>
                        <span class="font-mono text-[8px] tracking-[0.12em] text-white/24" data-ai-context-count>0 / 600</span>
                      </div>
                      <pre data-ai-prompt data-ai-prompt-template={section.aiPrompt}>{section.aiPrompt}</pre>
                      <button type="button" class="guide-copy-button mt-4" data-ai-copy>
                        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 8h11v11H8zM5 16H4V4h12v1" /></svg>
                        <span data-ai-copy-text>{copy.aiCopyLabel}</span>
                      </button>
                    </div>
                  </details>
                )}

                <footer class="flex flex-col gap-3 border-t border-white/10 px-5 py-4 sm:flex-row sm:items-center sm:justify-between sm:px-7">
                  <p class="text-xs leading-6 text-white/35">{section.checkpoint}</p>
                  <button type="button" class="guide-complete-button" aria-pressed="false" data-step-complete={index}>
                    <span data-complete-button-text>{copy.completeLabel}</span>
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m5 12 4 4L19 6" /></svg>
                  </button>
                </footer>
              </article>
            ))}

            <section class="guide-finale">
              <p class="text-[9px] font-mono uppercase tracking-[0.22em] text-cyan-200/60">Pull Request</p>
              <h3 class="mt-3 font-serif text-2xl tracking-[0.05em] text-white sm:text-3xl">{variant.finalTitle}</h3>
              <div class="wiki-guide-prose prose prose-invert mt-5 max-w-3xl" set:html={variant.finalBodyHtml} />
              <div class="mt-7 flex flex-wrap gap-3">
                <a href={docsHref} class="guide-secondary-action" target="_blank" rel="noopener noreferrer">{copy.docs}</a>
                <a
                  href={variant.entryMode === 'repository' ? repoContentRoot : docsHref}
                  class="guide-primary-action"
                  target="_blank"
                  rel="noopener noreferrer"
                  data-github-edit-link={variant.entryMode === 'repository' ? undefined : variant.key}
                >
                  <span>{variant.finalLinkLabel}</span>
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 17 17 7M8 7h9v9" /></svg>
                </a>
              </div>
            </section>
          </div>

          <aside class="space-y-4 lg:sticky lg:top-36">
            <section class="guide-focus-card">
              <p class="text-[9px] font-mono uppercase tracking-[0.2em] text-white/35">{copy.targetLabel}</p>
              <p class="mt-3 break-all font-mono text-xs leading-6 text-cyan-100/72" data-guide-target-path>{copy.invalidTarget}</p>
            </section>
            <section class="guide-glossary">
              <h3 class="font-serif text-lg tracking-[0.06em] text-white">{copy.glossaryTitle}</h3>
              <dl class="mt-4 divide-y divide-white/10">
                {copy.glossary.map((item) => (
                  <div class="py-3 first:pt-0 last:pb-0">
                    <dt class="font-mono text-[10px] text-cyan-100/78">{item.term}</dt>
                    <dd class="mt-1 text-xs leading-6 text-white/48">{item.definition}</dd>
                  </div>
                ))}
              </dl>
            </section>
          </aside>
        </div>
      </section>
    ))}

    <section id="syntax-reference" class="guide-reference border-t border-white/10 pt-12 sm:pt-16">
      <header class="guide-reference__header">
        <div>
          <p class="text-[9px] font-mono uppercase tracking-[0.22em] text-cyan-200/60">{learningCopy.referenceEyebrow}</p>
          <h2 class="mt-3 max-w-3xl font-serif text-3xl tracking-[0.05em] text-white sm:text-4xl">{learningCopy.referenceTitle}</h2>
          <p class="mt-5 max-w-3xl text-sm leading-7 text-white/55 sm:text-[15px] sm:leading-8">{learningCopy.referenceIntro}</p>
        </div>
        <ol aria-label={learningCopy.workflowTitle}>
          {learningCopy.workflow.map((step, index) => (
            <li><span>{String(index + 1).padStart(2, '0')}</span>{step}</li>
          ))}
        </ol>
      </header>

      <div class="guide-reference__layout">
        <aside class="guide-reference__toc">
          <p>{learningCopy.contents}</p>
          <TableOfContents headings={syntaxHeadings} title={learningCopy.contents} />
        </aside>

        <article class="wiki-reader wiki-prose prose prose-invert min-w-0 max-w-none">
          <Fragment set:html={syntaxHtml} />
        </article>

        <aside class="guide-reference__actions">
          <p class="font-serif text-lg tracking-[0.04em] text-white/82">{syntaxEntry.data.title}</p>
          <p class="mt-3 text-xs leading-6 text-white/46">{syntaxEntry.data.description}</p>
          <a href={syntaxStandaloneHref}>{learningCopy.standalone}</a>
          <a href={syntaxEditHref}>{learningCopy.editReference}</a>
          <a href="#choose-guide">{learningCopy.start}</a>
        </aside>
      </div>
    </section>
  </main>

  <SiteFooter footer={homeContent.footer} />
</BaseLayout>

<script is:inline type="module">
  const root = document.querySelector('[data-guide-runtime]');
  if (root instanceof HTMLElement) {
    const repoEditRoot = root.dataset.repoEditRoot || '';
    const repoContentRoot = root.dataset.repoContentRoot || '';
    const contentPathPrefix = root.dataset.contentPathPrefix || '';
    const docsHref = root.dataset.docsHref || '';
    const invalidTarget = root.dataset.invalidTarget || '';
    const defaultMode = root.dataset.defaultGuideMode || 'beginner';
    const availableModes = (root.dataset.guideModes || '').split(',').filter(Boolean);
    const completeLabel = root.dataset.completeLabel || '';
    const completedLabel = root.dataset.completedLabel || '';
    const progressLabel = root.dataset.progressLabel || '';
    const aiCopyLabel = root.dataset.aiCopyLabel || '';
    const aiCopiedLabel = root.dataset.aiCopiedLabel || '';
    const aiNoContext = root.dataset.aiNoContext || '';
    const aiGuardrails = root.dataset.aiGuardrails || '';

    const normalizeTarget = (value) => {
      let candidate = String(value || '').trim();
      for (let index = 0; index < 2; index += 1) {
        try {
          const decoded = decodeURIComponent(candidate);
          if (decoded === candidate) break;
          candidate = decoded;
        } catch { break; }
      }
      if (!candidate) return '';
      if (candidate.startsWith(contentPathPrefix)) return candidate;
      if (repoEditRoot && candidate.startsWith(repoEditRoot)) {
        const path = candidate.slice(repoEditRoot.length);
        return path.startsWith(contentPathPrefix) ? path : '';
      }
      return '';
    };

    const searchParams = new URLSearchParams(window.location.search);
    const rawTarget = searchParams.get('target') || '';
    const normalizedTarget = normalizeTarget(rawTarget);
    const resolvedTargetPath = normalizedTarget || invalidTarget;
    const resolvedEditHref = normalizedTarget ? `${repoEditRoot}${normalizedTarget}` : docsHref;
    const storageBase = `kamitsubaki-edit-guide:${normalizedTarget || 'general'}`;

    for (const node of root.querySelectorAll('[data-guide-target-path]')) node.textContent = resolvedTargetPath;
    const renderAiPrompt = (details) => {
      if (!(details instanceof HTMLDetailsElement)) return '';
      const preview = details.querySelector('[data-ai-prompt]');
      const context = details.querySelector('[data-ai-context]');
      if (!(preview instanceof HTMLElement)) return '';
      const template = preview.dataset.aiPromptTemplate || preview.textContent || '';
      const userContext = context instanceof HTMLTextAreaElement ? context.value.trim() : '';
      const prompt = template
        .replaceAll('{{TARGET_PATH}}', resolvedTargetPath)
        .replaceAll('{{REPO_CONTENT_ROOT}}', repoContentRoot)
        .replaceAll('{{USER_CONTEXT}}', userContext || aiNoContext);
      preview.textContent = `${prompt.trim()}\n\n【安全边界】\n${aiGuardrails}`;
      return preview.textContent;
    };
    for (const details of root.querySelectorAll('.guide-ai-help')) renderAiPrompt(details);
    for (const link of root.querySelectorAll('[data-github-edit-link]')) {
      if (link instanceof HTMLAnchorElement) link.href = resolvedEditHref;
    }

    const localeLinks = document.querySelectorAll('nav[aria-label="Language switcher"] a');
    const readProgress = (mode) => {
      try { return new Set(JSON.parse(localStorage.getItem(`${storageBase}:${mode}`) || '[]')); }
      catch { return new Set(); }
    };
    const saveProgress = (mode, completed) => {
      try { localStorage.setItem(`${storageBase}:${mode}`, JSON.stringify([...completed])); }
      catch { /* Progress persistence is an enhancement. */ }
    };

    const updatePanelProgress = (mode) => {
      const panel = root.querySelector(`[data-guide-mode-panel="${mode}"]`);
      if (!(panel instanceof HTMLElement)) return;
      const completed = readProgress(mode);
      const steps = panel.querySelectorAll('[data-guide-step]');
      const safeCompleted = new Set([...completed].filter((value) => Number(value) < steps.length));

      for (const step of steps) {
        if (!(step instanceof HTMLElement)) continue;
        const index = step.dataset.guideStep || '';
        step.dataset.completed = safeCompleted.has(index) ? 'true' : 'false';
      }
      for (const button of panel.querySelectorAll('[data-step-complete]')) {
        if (!(button instanceof HTMLButtonElement)) continue;
        const isCompleted = safeCompleted.has(button.dataset.stepComplete || '');
        button.setAttribute('aria-pressed', isCompleted ? 'true' : 'false');
        const label = button.querySelector('[data-complete-button-text]');
        if (label) label.textContent = isCompleted ? completedLabel : completeLabel;
      }
      for (const link of panel.querySelectorAll('[data-step-rail-link]')) {
        if (!(link instanceof HTMLElement)) continue;
        link.dataset.completed = safeCompleted.has(link.dataset.stepRailLink || '') ? 'true' : 'false';
      }
      for (const text of panel.querySelectorAll('[data-guide-progress-text]')) {
        text.textContent = `${progressLabel} ${safeCompleted.size} / ${steps.length}`;
      }
      for (const fill of panel.querySelectorAll('[data-guide-progress-fill]')) {
        if (fill instanceof HTMLElement) fill.style.width = `${steps.length ? (safeCompleted.size / steps.length) * 100 : 0}%`;
      }
    };

    const syncLocaleLinks = (mode) => {
      for (const node of localeLinks) {
        if (!(node instanceof HTMLAnchorElement)) continue;
        const href = new URL(node.href, window.location.origin);
        if (rawTarget) href.searchParams.set('target', normalizedTarget || rawTarget);
        else href.searchParams.delete('target');
        href.searchParams.set('mode', mode);
        node.href = `${href.pathname}${href.search}`;
      }
    };

    const syncMode = (mode) => {
      const activeMode = availableModes.includes(mode) ? mode : defaultMode;
      for (const button of root.querySelectorAll('[data-guide-mode-button]')) {
        if (!(button instanceof HTMLButtonElement)) continue;
        const active = button.dataset.guideModeButton === activeMode;
        button.setAttribute('aria-selected', active ? 'true' : 'false');
        button.dataset.guideModeActive = active ? 'true' : 'false';
        button.tabIndex = active ? 0 : -1;
      }
      for (const panel of root.querySelectorAll('[data-guide-mode-panel]')) {
        if (panel instanceof HTMLElement) panel.hidden = panel.dataset.guideModePanel !== activeMode;
      }
      updatePanelProgress(activeMode);
      syncLocaleLinks(activeMode);
      return activeMode;
    };

    const initialMode = syncMode(searchParams.get('mode') || defaultMode);

    for (const button of root.querySelectorAll('[data-guide-mode-button]')) {
      if (!(button instanceof HTMLButtonElement)) continue;
      button.addEventListener('click', () => {
        const mode = syncMode(button.dataset.guideModeButton || defaultMode);
        const url = new URL(window.location.href);
        url.searchParams.set('mode', mode);
        history.replaceState({}, '', `${url.pathname}${url.search}`);
        root.querySelector(`[data-guide-mode-panel="${mode}"]`)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
      button.addEventListener('keydown', (event) => {
        if (!['ArrowLeft', 'ArrowRight'].includes(event.key)) return;
        event.preventDefault();
        const current = availableModes.indexOf(button.dataset.guideModeButton || initialMode);
        const delta = event.key === 'ArrowRight' ? 1 : -1;
        const nextMode = availableModes[(current + delta + availableModes.length) % availableModes.length];
        const nextButton = root.querySelector(`[data-guide-mode-button="${nextMode}"]`);
        if (nextButton instanceof HTMLButtonElement) { nextButton.focus(); nextButton.click(); }
      });
    }

    root.querySelector('[data-guide-start]')?.addEventListener('click', () => {
      root.querySelector('[data-guide-chooser]')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });

    for (const button of root.querySelectorAll('[data-step-complete]')) {
      if (!(button instanceof HTMLButtonElement)) continue;
      button.addEventListener('click', () => {
        const panel = button.closest('[data-guide-mode-panel]');
        if (!(panel instanceof HTMLElement)) return;
        const mode = panel.dataset.guideModePanel || defaultMode;
        const index = button.dataset.stepComplete || '';
        const completed = readProgress(mode);
        if (completed.has(index)) completed.delete(index); else completed.add(index);
        saveProgress(mode, completed);
        updatePanelProgress(mode);
      });
    }

    for (const button of root.querySelectorAll('[data-guide-reset]')) {
      if (!(button instanceof HTMLButtonElement)) continue;
      button.addEventListener('click', () => {
        const panel = button.closest('[data-guide-mode-panel]');
        if (!(panel instanceof HTMLElement)) return;
        if (!window.confirm(button.dataset.resetConfirm || 'Reset progress?')) return;
        const mode = panel.dataset.guideModePanel || defaultMode;
        saveProgress(mode, new Set());
        updatePanelProgress(mode);
      });
    }

    for (const button of root.querySelectorAll('[data-ai-copy]')) {
      if (!(button instanceof HTMLButtonElement)) continue;
      button.addEventListener('click', async () => {
        const details = button.closest('details');
        const prompt = renderAiPrompt(details);
        try {
          await navigator.clipboard.writeText(prompt);
          const label = button.querySelector('[data-ai-copy-text]');
          if (label) label.textContent = aiCopiedLabel;
          window.setTimeout(() => { if (label) label.textContent = aiCopyLabel; }, 1800);
        } catch { window.prompt(aiCopyLabel, prompt); }
      });
    }

    for (const textarea of root.querySelectorAll('[data-ai-context]')) {
      if (!(textarea instanceof HTMLTextAreaElement)) continue;
      textarea.addEventListener('input', () => {
        const details = textarea.closest('details');
        const count = details?.querySelector('[data-ai-context-count]');
        if (count) count.textContent = `${textarea.value.length} / 600`;
        renderAiPrompt(details);
      });
    }

    if ('IntersectionObserver' in window) {
      for (const panel of root.querySelectorAll('[data-guide-mode-panel]')) {
        if (!(panel instanceof HTMLElement)) continue;
        const observer = new IntersectionObserver((entries) => {
          const visible = entries.filter((entry) => entry.isIntersecting).sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
          if (!(visible?.target instanceof HTMLElement)) return;
          const activeIndex = visible.target.dataset.guideStep || '';
          for (const link of panel.querySelectorAll('[data-step-rail-link]')) {
            if (link instanceof HTMLElement) link.dataset.active = link.dataset.stepRailLink === activeIndex ? 'true' : 'false';
          }
        }, { rootMargin: '-18% 0px -62% 0px', threshold: [0, 0.15, 0.5] });
        for (const step of panel.querySelectorAll('[data-guide-step]')) observer.observe(step);
      }
    }

    for (const mode of availableModes) updatePanelProgress(mode);
  }
</script>
