---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteNav from '../../../components/SiteNav.astro';
import SiteFooter from '../../../components/SiteFooter.astro';
import MusicSubnav from '../../../components/MusicSubnav.astro';
import { getLocalizedEntries, getLocalizedSite } from '../../../lib/homeData.mjs';
import { buildLocaleLinks, defaultLocale, supportedLocales } from '../../../lib/i18n.mjs';
import { buildArtistAlbumCatalog } from '../../../lib/musicCatalog.mjs';

export function getStaticPaths() {
  return supportedLocales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
const localeCode = locale as 'zh' | 'ja' | 'en';
const siteEntries = await getCollection('site');
const homeContent = getLocalizedSite(siteEntries, localeCode, defaultLocale);
const albumEntries = getLocalizedEntries(await getCollection('albums'), localeCode, defaultLocale);
const artistEntries = getLocalizedEntries(await getCollection('artists'), localeCode, defaultLocale);
const artistGroups = buildArtistAlbumCatalog(albumEntries, artistEntries, localeCode);
const localeLinks = buildLocaleLinks(homeContent, localeCode, '/albums');
const alternates = supportedLocales.map((code) => ({ locale: code, href: `/${code}/albums` }));
const copy = {
  zh: { title: '专辑作品', intro: '选择艺人，浏览其专辑、EP 与现场录音作品。', count: '张专辑', view: '进入艺人专辑库' },
  ja: { title: 'アルバム作品', intro: 'アーティストを選び、アルバム・EP・ライブ音源を閲覧できます。', count: '作品', view: 'アルバム一覧を見る' },
  en: { title: 'Albums', intro: 'Choose an artist to browse albums, EPs, and live recordings.', count: 'albums', view: 'Open album catalog' },
}[localeCode];
---

<BaseLayout lang={localeCode} alternates={alternates} title={`${copy.title} - Kamitsubaki Studio Fan Wiki`}>
  <div class="min-h-screen">
    <SiteNav navItems={homeContent.navItems} localeLinks={localeLinks} brandLines={homeContent.hero.brandLines} compact homeHref={`/${localeCode}/`} />

    <main class="mx-auto max-w-7xl px-5 py-24 sm:px-6">
      <div class="mb-8 max-w-2xl">
        <h1 class="font-serif text-3xl uppercase tracking-widest text-white">{copy.title}</h1>
        <p class="mt-3 text-sm leading-7 text-white/45">{copy.intro}</p>
      </div>
      <MusicSubnav locale={localeCode} current="albums" />

      <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {artistGroups.map((group) => (
          <a
            href={`/${localeCode}/albums/artists/${group.slug}`}
            class="album-artist-card group overflow-hidden border border-white/10 bg-white/[0.02] transition-colors hover:border-white/30 hover:bg-white/[0.05]"
            style={`--artist-accent:${group.theme?.accentColor ?? '#ffffff'}`}
          >
            <div class="relative aspect-[16/10] overflow-hidden bg-white/[0.035]">
              {group.cover ? (
                <img src={group.cover} alt="" class="h-full w-full object-cover opacity-70 grayscale-[20%] transition duration-700 group-hover:scale-[1.025] group-hover:opacity-95 group-hover:grayscale-0" loading="lazy" />
              ) : (
                <span class="grid h-full place-items-center font-serif text-5xl text-white/10">{group.artist.slice(0, 1)}</span>
              )}
              <div class="absolute inset-0 bg-gradient-to-t from-[#08090d] via-transparent to-transparent"></div>
              <span class="absolute bottom-4 left-4 font-mono text-[9px] uppercase tracking-[0.2em] text-white/55">
                {String(group.entries.length).padStart(2, '0')} {copy.count}
              </span>
            </div>
            <div class="p-6">
              <h2 class="truncate font-serif text-2xl tracking-wide text-white">{group.artist}</h2>
              {group.romanizedName && group.romanizedName !== group.artist && (
                <p class="mt-1 truncate font-mono text-[9px] uppercase tracking-[0.2em] text-white/30">{group.romanizedName}</p>
              )}
              <p class="mt-5 flex items-center justify-between border-t border-white/10 pt-4 font-mono text-[9px] uppercase tracking-[0.16em] text-white/35 transition-colors group-hover:text-white/75">
                <span>{copy.view}</span><span aria-hidden="true">→</span>
              </p>
            </div>
          </a>
        ))}
      </div>
    </main>

    <SiteFooter footer={homeContent.footer} />
  </div>
</BaseLayout>

<style>
  .album-artist-card {
    position: relative;
  }

  .album-artist-card::after {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    height: 1px;
    content: '';
    background: var(--artist-accent);
    opacity: 0;
    transform: scaleX(0.3);
    transition: opacity 300ms ease, transform 500ms ease;
  }

  .album-artist-card:hover::after,
  .album-artist-card:focus-visible::after {
    opacity: 0.75;
    transform: scaleX(1);
  }

  .album-artist-card:focus-visible {
    outline: 1px solid color-mix(in srgb, var(--artist-accent) 70%, white);
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    .album-artist-card img,
    .album-artist-card::after {
      transition: none;
    }
  }
</style>
