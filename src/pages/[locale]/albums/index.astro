---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteNav from '../../../components/SiteNav.astro';
import SiteFooter from '../../../components/SiteFooter.astro';
import MusicSubnav from '../../../components/MusicSubnav.astro';
import { getLocalizedEntries, getLocalizedSite } from '../../../lib/homeData.mjs';
import { buildLocaleLinks, defaultLocale, supportedLocales } from '../../../lib/i18n.mjs';

export function getStaticPaths() {
  return supportedLocales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
const localeCode = locale as 'zh' | 'ja' | 'en';
const siteEntries = await getCollection('site');
const homeContent = getLocalizedSite(siteEntries, localeCode, defaultLocale);
const albumEntries = getLocalizedEntries(await getCollection('albums'), localeCode, defaultLocale);
const compareOptionalNumber = (left?: number, right?: number) =>
  (left ?? Number.POSITIVE_INFINITY) - (right ?? Number.POSITIVE_INFINITY);
const sortedAlbums = [...albumEntries].sort((a, b) =>
  compareOptionalNumber(a.data.categoryOrder, b.data.categoryOrder)
  || compareOptionalNumber(a.data.itemOrder, b.data.itemOrder)
  || (b.data.releaseDate ?? '').localeCompare(a.data.releaseDate ?? '')
  || a.data.title.localeCompare(b.data.title, localeCode),
);
const localeLinks = buildLocaleLinks(homeContent, localeCode, '/albums');
const alternates = supportedLocales.map((code) => ({ locale: code, href: `/${code}/albums` }));
const copy = {
  zh: { title: '专辑作品', empty: '专辑词条正在整理中，欢迎参与补充。', type: '类型', release: '发行日期' },
  ja: { title: 'アルバム作品', empty: 'アルバム記事を準備中です。編集への参加を歓迎します。', type: '種類', release: 'リリース日' },
  en: { title: 'Albums', empty: 'Album entries are being prepared. Contributions are welcome.', type: 'Type', release: 'Release date' },
}[localeCode];
---

<BaseLayout lang={localeCode} alternates={alternates} title={`${copy.title} - Kamitsubaki Studio Fan Wiki`}>
  <div class="min-h-screen">
    <SiteNav navItems={homeContent.navItems} localeLinks={localeLinks} brandLines={homeContent.hero.brandLines} compact homeHref={`/${localeCode}/`} />

    <main class="mx-auto max-w-7xl px-5 py-24 sm:px-6">
      <h1 class="mb-8 font-serif text-3xl uppercase tracking-widest text-white">{copy.title}</h1>
      <MusicSubnav locale={localeCode} current="albums" />

      {sortedAlbums.length > 0 ? (
        <div class="mt-14 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {sortedAlbums.map((album) => {
            const albumPath = album.id.split('/').slice(0, -1).join('/');
            return (
              <a href={`/${localeCode}/albums/${albumPath}`} class="group overflow-hidden border border-white/10 bg-white/[0.02] transition-colors hover:border-white/30">
                {album.data.image && (
                  <img src={album.data.image} alt="" class="aspect-square w-full object-cover opacity-80 transition-opacity group-hover:opacity-100" loading="lazy" />
                )}
                <div class="p-6">
                  <h2 class="font-serif text-lg tracking-wide text-white">{album.data.title}</h2>
                  <p class="mt-2 text-sm text-white/50">{album.data.artist}</p>
                  {(album.data.type || album.data.releaseDate) && (
                    <dl class="mt-5 flex flex-wrap gap-x-6 gap-y-2 border-t border-white/10 pt-4 font-mono text-[9px] uppercase tracking-[0.16em] text-white/35">
                      {album.data.type && <div><dt class="sr-only">{copy.type}</dt><dd>{album.data.type}</dd></div>}
                      {album.data.releaseDate && <div><dt class="sr-only">{copy.release}</dt><dd>{album.data.releaseDate}</dd></div>}
                    </dl>
                  )}
                </div>
              </a>
            );
          })}
        </div>
      ) : (
        <p class="border-y border-white/10 py-12 text-sm tracking-wide text-white/45">{copy.empty}</p>
      )}
    </main>

    <SiteFooter footer={homeContent.footer} />
  </div>
</BaseLayout>
