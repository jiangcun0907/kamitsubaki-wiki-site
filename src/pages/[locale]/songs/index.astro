---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteNav from '../../../components/SiteNav.astro';
import SiteFooter from '../../../components/SiteFooter.astro';
import MusicSubnav from '../../../components/MusicSubnav.astro';
import { getCollection } from 'astro:content';
import { getLocalizedSite, getLocalizedEntries } from '../../../lib/homeData.mjs';
import { buildLocaleLinks, defaultLocale, supportedLocales } from '../../../lib/i18n.mjs';
import { groupMusicByArtist } from '../../../lib/musicCatalog.mjs';

export function getStaticPaths() {
  return supportedLocales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
const localeCode = locale as 'zh' | 'ja' | 'en';

const siteEntries = await getCollection('site');
const homeContent = getLocalizedSite(siteEntries, localeCode, defaultLocale);
const songEntries = getLocalizedEntries(await getCollection('songs'), localeCode, defaultLocale);

const localeLinks = buildLocaleLinks(homeContent, localeCode, `/songs`);
const alternates = supportedLocales.map((code) => ({ locale: code, href: `/${code}/songs` }));

const sortedSongs = [...songEntries].sort((a, b) =>
  (a.data.categoryOrder ?? Number.POSITIVE_INFINITY) - (b.data.categoryOrder ?? Number.POSITIVE_INFINITY)
  || (a.data.itemOrder ?? Number.POSITIVE_INFINITY) - (b.data.itemOrder ?? Number.POSITIVE_INFINITY)
  || a.data.title.localeCompare(b.data.title, localeCode),
);
type SongEntry = (typeof sortedSongs)[number];
const artistGroups = groupMusicByArtist(sortedSongs, localeCode) as Array<{
  artist: string;
  slug: string;
  id: string;
  entries: SongEntry[];
}>;
const copy = {
  zh: { title: '音乐作品', count: '首作品', view: '查看全部歌曲' },
  ja: { title: '楽曲作品', count: '曲', view: 'すべての楽曲を見る' },
  en: { title: 'Songs', count: 'tracks', view: 'View all songs' },
}[localeCode];
---

<BaseLayout lang={localeCode} alternates={alternates} title={`Songs - Kamitsubaki Studio Fan Wiki`}>
  <div class="min-h-screen">
    <SiteNav navItems={homeContent.navItems} localeLinks={localeLinks} brandLines={homeContent.hero.brandLines} compact homeHref={`/${localeCode}/`} />
    
    <main class="mx-auto max-w-7xl px-5 py-24 sm:px-6">
      <h1 class="font-serif text-3xl text-white mb-8 tracking-widest uppercase">{copy.title}</h1>
      <MusicSubnav locale={localeCode} current="songs" />

      <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {artistGroups.map((group) => (
          <a href={`/${localeCode}/songs/artists/${group.slug}`} class="group overflow-hidden border border-white/10 bg-white/[0.02] transition-colors hover:border-white/30 hover:bg-white/[0.05]">
            {group.entries[0]?.data.image && (
              <img src={group.entries[0].data.image} alt="" class="aspect-[16/10] w-full object-cover opacity-65 transition duration-500 group-hover:scale-[1.02] group-hover:opacity-90" loading="lazy" />
            )}
            <div class="p-6">
              <div class="flex items-end justify-between gap-4">
                <h2 class="font-serif text-2xl tracking-wide text-white">{group.artist}</h2>
                <span class="font-mono text-[9px] uppercase tracking-[0.16em] text-white/30">{group.entries.length} {copy.count}</span>
              </div>
              <p class="mt-5 border-t border-white/10 pt-4 font-mono text-[9px] uppercase tracking-[0.16em] text-white/35 transition-colors group-hover:text-white/65">{copy.view} →</p>
            </div>
          </a>
        ))}
      </div>
    </main>
    
    <SiteFooter footer={homeContent.footer} />
  </div>
</BaseLayout>
