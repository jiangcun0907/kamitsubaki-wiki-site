---
import { getCollection } from 'astro:content';
import MusicSubnav from '../../../../components/MusicSubnav.astro';
import SiteFooter from '../../../../components/SiteFooter.astro';
import SiteNav from '../../../../components/SiteNav.astro';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getLocalizedEntries, getLocalizedSite } from '../../../../lib/homeData.mjs';
import { buildLocaleLinks, defaultLocale, supportedLocales } from '../../../../lib/i18n.mjs';
import { groupMusicByArtist } from '../../../../lib/musicCatalog.mjs';

export async function getStaticPaths() {
  const allSongs = await getCollection('songs');

  return supportedLocales.flatMap((locale) => {
    const localizedSongs = getLocalizedEntries(allSongs, locale, defaultLocale);
    return groupMusicByArtist(localizedSongs, locale).map((group) => ({
      params: { locale, artist: group.slug },
      props: { songs: group.entries, artistName: group.artist },
    }));
  });
}

const { locale, artist } = Astro.params;
const { songs, artistName } = Astro.props;
const localeCode = locale as 'zh' | 'ja' | 'en';
const sortedSongs = [...songs].sort((a, b) =>
  (a.data.itemOrder ?? Number.POSITIVE_INFINITY) - (b.data.itemOrder ?? Number.POSITIVE_INFINITY)
  || (a.data.releaseDate ?? '').localeCompare(b.data.releaseDate ?? '')
  || a.data.title.localeCompare(b.data.title, localeCode),
);

const siteEntries = await getCollection('site');
const homeContent = getLocalizedSite(siteEntries, localeCode, defaultLocale);
const currentPath = `/songs/artists/${artist}`;
const localeLinks = buildLocaleLinks(homeContent, localeCode, currentPath);
const alternates = supportedLocales.map((code) => ({ locale: code, href: `/${code}${currentPath}` }));
const copy = {
  zh: { back: '全部艺人', count: '首歌曲', album: '收录专辑' },
  ja: { back: 'すべてのアーティスト', count: '曲', album: '収録アルバム' },
  en: { back: 'All artists', count: 'songs', album: 'Album' },
}[localeCode];
---

<BaseLayout lang={localeCode} alternates={alternates} title={`${artistName} - Kamitsubaki Studio Fan Wiki`}>
  <div class="min-h-screen">
    <SiteNav navItems={homeContent.navItems} localeLinks={localeLinks} brandLines={homeContent.hero.brandLines} compact homeHref={`/${localeCode}/`} />

    <main class="mx-auto max-w-7xl px-5 py-24 sm:px-6">
      <a href={`/${localeCode}/songs`} class="font-mono text-[9px] uppercase tracking-[0.18em] text-white/40 transition-colors hover:text-white">← {copy.back}</a>
      <div class="mb-8 mt-7 flex flex-wrap items-end justify-between gap-4">
        <h1 class="font-serif text-3xl uppercase tracking-widest text-white">{artistName}</h1>
        <span class="font-mono text-[9px] uppercase tracking-[0.16em] text-white/30">{sortedSongs.length} {copy.count}</span>
      </div>
      <MusicSubnav locale={localeCode} current="songs" />

      <div class="mt-14 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {sortedSongs.map((song, index) => {
          const songPath = song.id.split('/').slice(0, -1).join('/');
          return (
            <a href={`/${localeCode}/songs/${songPath}`} class="group flex items-center gap-4 border border-white/10 bg-white/[0.02] p-4 transition-colors hover:border-white/30 hover:bg-white/[0.05]">
              {song.data.image ? (
                <img src={song.data.image} alt="" class="h-16 w-16 shrink-0 object-cover" loading="lazy" />
              ) : (
                <span class="grid h-16 w-16 shrink-0 place-items-center bg-white/5 font-mono text-[10px] text-white/25">{String(index + 1).padStart(2, '0')}</span>
              )}
              <span class="min-w-0">
                <strong class="block truncate font-serif text-base font-normal tracking-wide text-white/85 group-hover:text-white">{song.data.title}</strong>
                <span class="mt-1 block truncate text-[10px] tracking-wide text-white/40">{song.data.album ? `${copy.album}: ${song.data.album}` : artistName}</span>
              </span>
            </a>
          );
        })}
      </div>
    </main>

    <SiteFooter footer={homeContent.footer} />
  </div>
</BaseLayout>
