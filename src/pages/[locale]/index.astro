---
import AboutSection from '../../components/AboutSection.astro';
import AnnouncementModal from '../../components/AnnouncementModal.astro';
import AlbumsSection from '../../components/AlbumsSection.astro';
import ArtistDatabase from '../../components/ArtistDatabase.astro';
import ContributorRoster from '../../components/ContributorRoster.astro';
import Hero from '../../components/Hero.astro';
import LogSection from '../../components/LogSection.astro';
import ProjectsSection from '../../components/ProjectsSection.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import SiteNav from '../../components/SiteNav.astro';
import SongsSection from '../../components/SongsSection.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { buildArtistCategories, buildDatabaseJumpLinks, buildLogCards, buildProjectCards, getLocalizedEntries, getLocalizedSite } from '../../lib/homeData.mjs';
import { buildLocaleLinks, defaultLocale, supportedLocales } from '../../lib/i18n.mjs';
import { buildHomeMetadata } from '../../lib/metadata.mjs';

export function getStaticPaths() {
  return supportedLocales.map((locale) => ({
    params: { locale },
  }));
}

const { locale } = Astro.params;
const siteEntries = await getCollection('site');
const homeContent = getLocalizedSite(siteEntries, locale, defaultLocale);
const artistEntries = getLocalizedEntries(await getCollection('artists'), locale, defaultLocale);
const projectEntries = getLocalizedEntries(await getCollection('projects'), locale, defaultLocale);
const logEntryCollection = getLocalizedEntries(await getCollection('logs'), locale, defaultLocale);
const announcementEntries = getLocalizedEntries(await getCollection('announcements'), locale, defaultLocale);
const songEntries = getLocalizedEntries(await getCollection('songs'), locale, defaultLocale);
const songs = songEntries.slice(0, 4);
const compareOptionalNumber = (left?: number, right?: number) =>
  (left ?? Number.POSITIVE_INFINITY) - (right ?? Number.POSITIVE_INFINITY);
const albumEntries = getLocalizedEntries(await getCollection('albums'), locale, defaultLocale);
const albums = [...albumEntries]
  .sort((a, b) =>
    compareOptionalNumber(a.data.categoryOrder, b.data.categoryOrder)
    || compareOptionalNumber(a.data.itemOrder, b.data.itemOrder)
    || (b.data.releaseDate ?? '').localeCompare(a.data.releaseDate ?? ''),
  )
  .slice(0, 4);

const artistCategories = buildArtistCategories(artistEntries);
const databaseJumpLinks = buildDatabaseJumpLinks(artistCategories);
const projects = buildProjectCards(projectEntries, locale);
const logEntries = buildLogCards(logEntryCollection, locale);
const announcements = [...announcementEntries]
  .sort((a, b) => Number(Boolean(b.data.pinned)) - Number(Boolean(a.data.pinned)) || a.data.order - b.data.order)
  .map((entry) => ({ id: entry.id, ...entry.data }));
const featuredAnnouncement = announcements.find((announcement) => announcement.pinned) ?? announcements[0];
const announcementModalLabels = {
  zh: { open: '查看重要公告', close: '知道了' },
  ja: { open: '重要なお知らせを表示', close: '閉じる' },
  en: { open: 'View important notice', close: 'Close' },
}[locale];
const localeLinks = buildLocaleLinks(homeContent, locale);
const alternates = supportedLocales.map((localeCode) => ({
  locale: localeCode,
  href: `/${localeCode}/`,
}));
const metadata = buildHomeMetadata(homeContent, locale);
---

<BaseLayout lang={locale} alternates={alternates} metadata={metadata}>
  <div data-page-context-root>
    <SiteNav navItems={homeContent.navItems} localeLinks={localeLinks} brandLines={homeContent.hero.brandLines} homeHref={`/${locale}/`} />
    <AnnouncementModal announcement={featuredAnnouncement} labels={announcementModalLabels} />
    <Hero hero={homeContent.hero} />
    <AboutSection content={homeContent.sections.about} />
    <ArtistDatabase
      artistCategories={artistCategories}
      databaseJumpLinks={databaseJumpLinks}
      section={homeContent.sections.database}
      locale={locale}
    />
    <SongsSection songs={songs} section={homeContent.sections.songs} locale={locale} />
    <AlbumsSection albums={albums} section={homeContent.sections.albums} locale={locale} />
    <ContributorRoster mode="summary" locale={locale} />
    <ProjectsSection projects={projects} section={homeContent.sections.projects} />
    <LogSection logEntries={logEntries} section={homeContent.sections.log} />
    <SiteFooter footer={homeContent.footer} />
  </div>
</BaseLayout>
